APP_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://nidhiflow:replace-with-a-local-password@localhost:5432/nidhiflow
DATABASE_SSL=false
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
FEEDBACK_RATE_LIMIT_MAX=5
ANDROID_NOTIFICATION_TRANSACTIONS_ENABLED=false
DIRECT_UPI_ENABLED=false
FLOW_AI_ENABLED=false
FLOW_AI_TIMEOUT_MS=60000
FLOW_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
APP_PUBLIC_URL=http://localhost:5173
EMAIL_DELIVERY_PROVIDER=none
EMAIL_FROM=
RESEND_API_KEY=
JWT_ACCESS_SECRET=
JWT_ACCESS_ISSUER=nidhiflow.local
JWT_ACCESS_AUDIENCE=nidhiflow-app
JWT_ACCESS_TTL_SECONDS=900
REFRESH_SESSION_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=2
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_USER=nidhiflow
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_DB=nidhiflow

NIDHIFLOW_API_BASE_URL=http://127.0.0.1:3000
